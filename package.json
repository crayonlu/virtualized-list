{
	"name": "lite-virtualized-list",
	"version": "0.1.0",
	"description": "Lightweight React virtualized list with dynamic height support",
	"license": "MIT",
	"type": "module",
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"scripts": {
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check .",
		"check:write": "biome check --write .",
		"build": "tsup",
		"prepublishOnly": "npm run build"
	},
	"keywords": [
		"react",
		"virtualized-list",
		"infinite-scroll",
		"performance"
	],
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/bun": "latest",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"tsup": "^8.5.1",
		"typescript": "^5.0.0"
	},
	"peerDependencies": {
		"react": ">=18.0.0",
		"react-dom": ">=18.0.0"
	}
}
